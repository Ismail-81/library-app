rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ================= HELPERS =================
    function isAuthenticated() {
      return request.auth != null;
    }

    function userExists() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return userExists() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ================= USERS =================
    match /users/{userId} {
      // Users can read their own profile, admin can read all
      allow read: if isAuthenticated() &&
        (request.auth.uid == userId || isAdmin());

      // User can create their own profile
      allow create: if isAuthenticated() && request.auth.uid == userId;

      // User can update own profile, admin can update any
      allow update: if isAuthenticated() &&
        (request.auth.uid == userId || isAdmin());

      // Only admin can delete users
      allow delete: if isAdmin();
    }

    // ================= BOOKS =================
    match /books/{bookId} {
      // Anyone can read books
      allow read: if true;

      // Only admin can create/update/delete
      allow create, update, delete: if isAdmin();
    }

    // ================= ISSUED BOOKS =================
    match /issuedBooks/{issueId} {
      // Admin can read all, user can read their own issued books
      allow read: if isAuthenticated() &&
        (isAdmin() || resource.data.userId == request.auth.uid);

      // Any logged-in user can create an issue
      allow create: if isAuthenticated();

      // User can update their own issued books, admin can update all
      allow update: if isAuthenticated() &&
        (isAdmin() || resource.data.userId == request.auth.uid);

      // Only admin can delete
      allow delete: if isAdmin();
    }

    // ================= CATEGORIES =================
    match /categories/{catId} {
      // Public read
      allow read: if true;

      // Only admin can modify
      allow create, update, delete: if isAdmin();
    }

    // ================= NOTIFICATIONS =================
    match /notifications/{notifId} {
      // User can read their own notifications
      allow read: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;

      // Any logged-in user can create
      allow create: if isAuthenticated();

      // User can update their own notifications
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;

      // Only admin can delete
      allow delete: if isAdmin();
    }

    // ================= DEFAULT DENY =================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}